{
  "name": "crafting",
  "version": "2.0.0",
  "private": false,
  "scripts": {
    "dev": "vite",
    "generate:tags": "bun scripts/fetch-tags.ts",
    "generate:bedrock": "bun scripts/fetch-bedrock-mappings.ts",
    "prebuild": "pnpm generate:tags && pnpm generate:bedrock",
    "build": "tsc && vite build",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "preview": "vite preview",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.0",
    "@floating-ui/react": "^0.27.19",
    "@jongwooo/prism-theme-github": "^1.15.1",
    "@nozbe/microfuzz": "^1.0.0",
    "@tanstack/react-virtual": "^3.13.24",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "immer": "^11.1.4",
    "lucide-react": "^1.8.0",
    "minecraft-textures": "^26.1.0",
    "modern-screenshot": "^4.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tiny-invariant": "^1.3.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
