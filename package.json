    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-start": "^1.168.11",
    "@tanstack/react-virtual": "^3.13.25",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "immer": "^11.1.8",
    "lucide-react": "^1.16.0",
