{
  "name": "crafting",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "generate:vanilla-data": "bun scripts/vanilla-data/index.ts",
    "generate:bedrock": "bun scripts/fetch-bedrock-mappings.ts",
    "generate:data": "pnpm generate:vanilla-data && pnpm generate:bedrock",
    "build": "tsc && vite build",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "preview": "vite preview",
    "test": "vitest run",
    "type-check": "tsc --noEmit && tsc -p scripts --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@floating-ui/react": "^0.27.20",
    "@jongwooo/prism-theme-github": "^1.15.1",
    "@nozbe/microfuzz": "^1.0.0",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.32",
    "@tanstack/react-virtual": "^3.14.8",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "immer": "^11.1.15",
    "lucide-react": "^1.25.0",
    "minecraft-textures": "26.2.1",
    "modern-screenshot": "^4.7.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "^7.0.2001",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.10"
  }
}
